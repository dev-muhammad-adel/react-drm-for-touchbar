{
  "name": "react-drm",
  "version": "0.1.0",
  "private": true,
  "description": "React renderer targeting Linux DRM/KMS via libdrm + Cairo",
  "license": "GPL-3.0-or-later",
  "author": "Muhammad Adel",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "workspaces": [
    "linux-touchbar-control-center"
  ],
  "scripts": {
    "build:native": "node-gyp configure build",
    "build:ts": "tsc",
    "build": "npm run build:native && npm run build:ts"
  },
  "dependencies": {
    "@react-spring/animated": "^10.1.1",
    "@react-spring/core": "^10.1.1",
    "color-string": "^2.1.4",
    "gifuct-js": "^2.1.2",
    "node-addon-api": "^8.3.0",
    "react": "^18.3.1",
    "react-reconciler": "^0.29.2",
    "yoga-layout": "^3.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.20",
    "@types/react-reconciler": "^0.28.8",
    "node-gyp": "^12.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  },
  "gypfile": true,
  "overrides": {
    "tmp": "^0.2.7"
  }
}
